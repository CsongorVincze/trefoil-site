---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import BoidBackground from '../../components/BoidBackground.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');
const learnPosts = allPosts
  .filter((p) => p.data.category === 'learn' && !p.data.prev)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tag → label map for display
const topicLabels: Record<string, string> = {
  'linear-algebra': 'Linear Algebra',
  'analysis':       'Multivariable Analysis',
  'topology':       'Topology',
  'physics':        'Physics',
  'simulation':     'Simulation',
  'math':           'Mathematics',
};

// Series titles for grouping
const seriesTitles: Record<string, string> = {
  'vektorterek': 'Vektorterek',
  'multi-var-anal': 'Multivariable Analysis',
  'oscillations': 'Rezgések (Oscillations)',
  'electro': 'Electrostatics'
};

// Icon per first-tag group
const topicIcons: Record<string, string> = {
  'linear-algebra': '∑',
  'analysis':       '∂',
  'physics':        '∿',
  'simulation':     '⚙',
  'math':           'π',
};

function iconForPost(tags: string[] = []) {
  for (const t of tags) if (topicIcons[t]) return topicIcons[t];
  return '📖';
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Learn — ${SITE_TITLE}`} description="Study materials on math and physics topics." />
  </head>
  <body>
    <BoidBackground />
    <Header />
    <main>
      <p class="eyebrow">Study materials</p>
      <h1>Learn</h1>
      <p class="subtitle">
        Pick a topic and dive in.
      </p>

      <ul class="card-grid">
        {learnPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="card">
              <span class="card-icon">{iconForPost(post.data.tags)}</span>
              <div class="card-body">
                <div class="card-tags">
                  {(post.data.tags ?? []).map((t) => (
                    <span class="tag">{topicLabels[t] ?? t}</span>
                  ))}
                </div>
                <h2 class="card-title">{post.data.seriesId && seriesTitles[post.data.seriesId] ? seriesTitles[post.data.seriesId] : post.data.title}</h2>
                <p class="card-desc">{post.data.description}</p>
                <p class="card-date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <style>
      /* ── Entrance animation ── */
      @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      main {
        max-width: 900px;
        margin: auto;
        padding: 5em 1.5em 4em;
      }

      .eyebrow {
        font-size: 0.8em;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--frosted-blue);
        margin-bottom: 0.25em;
        opacity: 0.8;
        animation: fadeSlideUp 0.7s ease both;
        animation-delay: 0.05s;
      }

      h1 {
        font-size: 3.5em;
        color: var(--honeydew);
        margin: 0 0 0.25em;
        line-height: 1.1;
        animation: fadeSlideUp 0.7s ease both;
        animation-delay: 0.15s;
      }

      .subtitle {
        font-size: 1.05em;
        color: var(--frosted-blue);
        opacity: 0.75;
        margin-bottom: 2.5em;
        max-width: 50ch;
        animation: fadeSlideUp 0.7s ease both;
        animation-delay: 0.25s;
      }

      /* ── Card grid ── */
      .card-grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }

      .card-grid li {
        animation: fadeSlideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .card-grid li:nth-child(1) { animation-delay: 0.3s; }
      .card-grid li:nth-child(2) { animation-delay: 0.4s; }
      .card-grid li:nth-child(3) { animation-delay: 0.5s; }
      .card-grid li:nth-child(4) { animation-delay: 0.6s; }

      .card {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: rgba(29, 53, 87, 0.55);    /* oxford-navy semi-transparent */
        border: 1px solid rgba(168, 218, 220, 0.18);
        border-radius: 16px;
        padding: 1.75rem;
        text-decoration: none;
        color: inherit;
        backdrop-filter: blur(10px);
        transition:
          transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
          border-color 0.3s ease,
          box-shadow 0.3s ease;
        height: 100%;
        box-sizing: border-box;
      }

      .card:hover {
        transform: translateY(-6px);
        border-color: var(--frosted-blue);
        box-shadow:
          0 16px 40px rgba(0, 0, 0, 0.35),
          0 0 0 1px rgba(168, 218, 220, 0.2);
      }

      .card-icon {
        font-size: 2.2em;
        margin-bottom: 0.8rem;
        display: block;
        line-height: 1;
        filter: drop-shadow(0 0 8px rgba(168, 218, 220, 0.4));
      }

      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-bottom: 0.75rem;
      }

      .tag {
        font-size: 0.68em;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cerulean);
        background: rgba(69, 123, 157, 0.15);
        border: 1px solid rgba(69, 123, 157, 0.3);
        border-radius: 999px;
        padding: 0.2em 0.65em;
      }

      .card-title {
        font-size: 1.2em;
        color: var(--honeydew);
        margin: 0 0 0.5rem;
        line-height: 1.3;
      }

      .card-desc {
        font-size: 0.88em;
        color: var(--frosted-blue);
        opacity: 0.8;
        line-height: 1.6;
        margin: 0 0 1rem;
        flex: 1;
      }

      .card-date {
        font-size: 0.78em;
        color: var(--frosted-blue);
        opacity: 0.5;
        margin: 0;
        margin-top: auto;
      }

      @media (max-width: 600px) {
        .card-grid {
          grid-template-columns: 1fr;
        }
        h1 { font-size: 2.5em; }
      }
    </style>
  </body>
</html>
