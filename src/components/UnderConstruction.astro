---
interface Props {
  lang?: 'hu' | 'en';
  message?: string;
}

const { lang = 'hu' } = Astro.props;

const defaultMessage =
  lang === 'en'
    ? 'This section is still under construction. Content may be incomplete or subject to change.'
    : 'Ez a fejezet még nem készült el teljesen. A tartalom hiányos lehet, vagy változhat.';

const title = lang === 'en' ? 'Under Construction' : 'Fejlesztés alatt';
const { message = defaultMessage } = Astro.props;
---

<div class="construction-banner" role="note" aria-label={title}>
  <div class="construction-header">
    <span class="construction-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
        <line x1="12" y1="9" x2="12" y2="13" />
        <line x1="12" y1="17" x2="12.01" y2="17" />
      </svg>
    </span>
    <span class="construction-title">{title}</span>
    <span class="construction-tape-strip" aria-hidden="true">
      <span class="tape-segment"></span>
      <span class="tape-segment"></span>
      <span class="tape-segment"></span>
      <span class="tape-segment"></span>
      <span class="tape-segment"></span>
      <span class="tape-segment"></span>
    </span>
  </div>
  <div class="construction-body">
    <p class="construction-message">{message}</p>
  </div>
</div>

<style>
  .construction-banner {
    border: 2px solid #f4a936;
    border-radius: 12px;
    overflow: hidden;
    margin: 2rem 0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(244, 169, 54, 0.15);
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(244, 169, 54, 0.15);
    }
    50% {
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2), 0 0 12px rgba(244, 169, 54, 0.3);
    }
  }

  .construction-header {
    width: 100%;
    background: linear-gradient(135deg, #d97706, #f59e0b);
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  /* Hazard stripe overlay on the header */
  .construction-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      rgba(0, 0, 0, 0.08) 10px,
      rgba(0, 0, 0, 0.08) 20px
    );
    pointer-events: none;
  }

  .icon-svg {
    width: 1.3rem;
    height: 1.3rem;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.2));
  }

  .construction-icon {
    display: flex;
    align-items: center;
    color: #1d3557;
    position: relative;
    z-index: 1;
    animation: icon-bounce 2.5s ease-in-out infinite;
  }

  @keyframes icon-bounce {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-3px); }
    60% { transform: translateY(-1px); }
  }

  .construction-title {
    font-weight: 700;
    font-size: 1.1rem;
    color: #1d3557;
    letter-spacing: 0.03em;
    position: relative;
    z-index: 1;
  }

  /* The tape strips on the right side of the header */
  .construction-tape-strip {
    display: flex;
    gap: 3px;
    margin-left: auto;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .tape-segment {
    width: 12px;
    height: 20px;
    border-radius: 2px;
    background: #1d3557;
    opacity: 0.7;
    animation: tape-flicker 1.8s ease-in-out infinite;
  }

  .tape-segment:nth-child(2) { animation-delay: 0.15s; opacity: 0.5; }
  .tape-segment:nth-child(3) { animation-delay: 0.3s; opacity: 0.65; }
  .tape-segment:nth-child(4) { animation-delay: 0.45s; opacity: 0.5; }
  .tape-segment:nth-child(5) { animation-delay: 0.6s; opacity: 0.65; }
  .tape-segment:nth-child(6) { animation-delay: 0.75s; opacity: 0.5; }

  @keyframes tape-flicker {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 0.35; }
  }

  .construction-body {
    padding: 1rem 1.5rem;
    background-color: #fffbeb;
    border-top: 1px solid #f4a936;
  }

  .construction-message {
    margin: 0;
    font-size: 0.95rem;
    color: #78350f;
    line-height: 1.6;
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    .construction-banner {
      border-color: #f59e0b;
    }

    .construction-header {
      background: linear-gradient(135deg, #92400e, #b45309);
    }

    .construction-title {
      color: #fef3c7;
    }

    .construction-icon {
      color: #fef3c7;
    }

    .tape-segment {
      background: #fef3c7;
    }

    .construction-body {
      background-color: rgba(245, 158, 11, 0.08);
      border-top-color: #b45309;
    }

    .construction-message {
      color: #fde68a;
    }
  }
</style>
